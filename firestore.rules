rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APP SECURITY STRATEGY: Path-Based Ownership (Prototyping Mode)
     *
     * Core Philosophy: This ruleset enforces a strict user-ownership model where all data
     * is architecturally siloed under the owner's UID. Access is granted only if the
     * authenticated user matches the path's userId.
     *
     * Data Structure: All application data is nested under /users/{userId}/...
     * to ensure absolute data isolation and simplify authorization logic.
     *
     * Key Security Decisions:
     * 1. Ownership Enforcement: Every write operation validates that the document's 
     *    internal 'userId' field matches the path and the authenticated user's UID.
     * 2. Prototyping Flexibility: Data types and general schema shapes are not 
     *    validated to allow for rapid UI/UX iteration. Only relational integrity 
     *    fields (like userId) are strictly enforced.
     * 3. Denormalization: Critical IDs (userId, parent IDs) are expected to be 
     *    present on child documents to allow for high-performance rules that 
     *    avoid costly get() lookups.
     * 4. Implicit Deny: All access is denied by default unless explicitly granted.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated with a valid UID. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the current user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a document exists and belongs to the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates that the data's userId field matches the authorized user. */
    function hasValidOwnerField(userId) {
      return request.resource.data.userId == userId;
    }

    /** @description Ensures a field remains unchanged during an update. */
    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the user profile document.
     * @path /users/{userId}
     * @allow (create, get, update) if UID matches userId.
     * @deny (list, delete) to prevent user enumeration or self-deletion from client.
     * @principle Self-creation and ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing users
      allow create: if isOwner(userId) && hasValidOwnerField(userId);
      allow update: if isExistingOwner(userId) && isUnchanged('userId');
      allow delete: if false; // Delete usually handled via Admin SDK/Functions

      /**
       * @description Records of bike rides, runs, or swims.
       * @path /users/{userId}/activities/{activityId}
       * @allow (create, list, get, update, delete) if user is owner.
       * @deny if userId in path/data mismatch.
       * @principle Path-based ownership with relational field validation.
       */
      match /activities/{activityId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User's overarching training plans.
       * @path /users/{userId}/trainingPlans/{trainingPlanId}
       * @allow (all) if user is owner.
       * @principle Owner-only access.
       */
      match /trainingPlans/{trainingPlanId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Sessions scheduled within a specific plan.
         * @path /users/{userId}/trainingPlans/{trainingPlanId}/trainingSessions/{sessionId}
         * @allow (create) if userId and trainingPlanId are correctly set in data.
         * @principle Relational integrity for nested child documents.
         */
        match /trainingSessions/{sessionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidOwnerField(userId) && request.resource.data.trainingPlanId == trainingPlanId;
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('trainingPlanId');
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description User's bicycle inventory.
       * @path /users/{userId}/bikes/{bikeId}
       * @allow (all) if user is owner.
       * @principle Path-based ownership.
       */
      match /bikes/{bikeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Parts installed on a specific bike.
         * @path /users/{userId}/bikes/{bikeId}/components/{componentId}
         * @principle Ensures component is linked to the correct bike and user.
         */
        match /components/{componentId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidOwnerField(userId) && request.resource.data.bikeId == bikeId;
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('bikeId');
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Tire pressure settings for a bike and specific terrain.
         * @path /users/{userId}/bikes/{bikeId}/tirePressureSetups/{setupId}
         */
        match /tirePressureSetups/{setupId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidOwnerField(userId) && request.resource.data.bikeId == bikeId;
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('bikeId');
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Logs of maintenance performed.
       * @path /users/{userId}/maintenanceRecords/{recordId}
       */
      match /maintenanceRecords/{recordId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User's private recipe collection.
       * @path /users/{userId}/recipes/{recipeId}
       */
      match /recipes/{recipeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Ingredients specifically linked to a recipe.
         * @path /users/{userId}/recipes/{recipeId}/recipeIngredients/{recipeIngredientId}
         */
        match /recipeIngredients/{recipeIngredientId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.recipeId == recipeId;
          allow update: if isExistingOwner(userId) && isUnchanged('recipeId');
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Custom tags for categorization.
       * @path /users/{userId}/tags/{tagId}
       */
      match /tags/{tagId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description User-defined ingredient master list.
       * @path /users/{userId}/ingredients/{ingredientId}
       */
      match /ingredients/{ingredientId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Inventory of cycling clothing for weather suggestions.
       * @path /users/{userId}/cyclingClothingItems/{itemId}
       */
      match /cyclingClothingItems/{itemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Indoor plant management.
       * @path /users/{userId}/plants/{plantId}
       */
      match /plants/{plantId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Logs for watering/care actions.
         * @path /users/{userId}/plants/{plantId}/plantActions/{actionId}
         */
        match /plantActions/{actionId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidOwnerField(userId) && request.resource.data.plantId == plantId;
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('plantId');
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Current items in stock (fridge/pantry).
       * @path /users/{userId}/pantryItems/{pantryItemId}
       */
      match /pantryItems/{pantryItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Active shopping list items.
       * @path /users/{userId}/shoppingListItems/{shoppingListItemId}
       */
      match /shoppingListItems/{shoppingListItemId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Personalized expense categories.
       * @path /users/{userId}/expenseCategories/{categoryId}
       */
      match /expenseCategories/{categoryId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Monthly financial budget definitions.
       * @path /users/{userId}/monthlyBudgets/{monthlyBudgetId}
       */
      match /monthlyBudgets/{monthlyBudgetId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);

        /**
         * @description Category-specific allocations within a budget.
         * @path /users/{userId}/monthlyBudgets/{monthlyBudgetId}/budgetAllocations/{allocationId}
         */
        match /budgetAllocations/{allocationId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && hasValidOwnerField(userId) && request.resource.data.monthlyBudgetId == monthlyBudgetId;
          allow update: if isExistingOwner(userId) && isUnchanged('userId') && isUnchanged('monthlyBudgetId');
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Log of financial expenditures.
       * @path /users/{userId}/expenses/{expenseId}
       */
      match /expenses/{expenseId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Personal tasks, reminders, and alerts.
       * @path /users/{userId}/tasks/{taskId}
       */
      match /tasks/{taskId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Recorded health metrics (weight, sleep, etc).
       * @path /users/{userId}/healthMetrics/{metricId}
       */
      match /healthMetrics/{metricId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Health and wellness objectives.
       * @path /users/{userId}/healthGoals/{goalId}
       */
      match /healthGoals/{goalId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && hasValidOwnerField(userId);
        allow update: if isExistingOwner(userId) && isUnchanged('userId');
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}