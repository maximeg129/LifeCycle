
{
  "entities": {
    "UserSettings": {
      "title": "User Settings",
      "description": "User specific configuration for external integrations.",
      "type": "object",
      "properties": {
        "intervalsAthleteId": {
          "type": "string",
          "description": "The Intervals.icu athlete ID found in settings."
        },
        "intervalsApiKey": {
          "type": "string",
          "description": "The Intervals.icu API key generated in settings."
        }
      },
      "required": ["intervalsAthleteId", "intervalsApiKey"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A personal recipe stored in the user's cookbook.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "imageHint": { "type": "string" }
      },
      "required": ["title", "ingredients", "instructions"]
    },
    "Task": {
      "title": "Household Task",
      "description": "A smart recurring household chore.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "room": { "type": "string", "enum": ["Cuisine", "Salon", "Chambre", "SdB", "Extérieur", "Général"] },
        "estimatedMinutes": { "type": "number" },
        "recurrenceDays": { "type": "number" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "lastCompleted": { "type": "string", "format": "date-time" },
        "nextDueDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "room", "recurrenceDays", "priority"]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}/settings/intervals": {
      "schema": "UserSettings",
      "description": "Stored Intervals.icu credentials for a user."
    },
    "/users/{userId}/recipes": {
      "schema": "Recipe",
      "description": "User's personal cookbook collection."
    },
    "/users/{userId}/tasks": {
      "schema": "Task",
      "description": "User's household chore list."
    }
  }
}
